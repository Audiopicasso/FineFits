# ============================================================================
# FineFits — Produktion (Raspberry Pi + OpenAI)
# ============================================================================
# Kopieren nach .env auf dem Pi und alle Platzhalter ersetzen.
# Secrets erzeugen: openssl rand -hex 32
# ============================================================================

# --- Domain & URLs (HTTPS Pflicht für Produktion) ---
APP_URL=https://finefits.deine-domain.de
NEXTAUTH_URL=https://finefits.deine-domain.de

# --- Branding ---
APP_NAME=FineFits
MOBILE_APP_SCHEME=finefits

# --- Secrets (NIEMALS die Dev-Defaults verwenden) ---
SECRET_KEY=GENERIERE-MIT-openssl-rand-hex-32
NEXTAUTH_SECRET=GENERIERE-MIT-openssl-rand-hex-32
POSTGRES_PASSWORD=GENERIERE-STARKES-PASSWORT

POSTGRES_USER=wardrobe
POSTGRES_DB=wardrobe

# --- Auth: OIDC (Pflicht in Produktion — kein DEBUG) ---
# Beispiel Pocket ID / Authentik / Keycloak — Redirect-URI:
#   https://finefits.deine-domain.de/api/auth/callback/oidc
OIDC_ISSUER_URL=https://auth.deine-domain.de
OIDC_CLIENT_ID=finefits
OIDC_CLIENT_SECRET=DEIN-OIDC-CLIENT-SECRET
# OIDC_END_SESSION_URL=https://auth.deine-domain.de/.../end-session

# Kein Dev-Login in Produktion
# DEBUG=false

# Forward-Auth nur wenn du TinyAuth/Authelia vor nginx hast
AUTH_TRUST_HEADER=false

# --- OpenAI (kostengünstig: gpt-4o-mini für Vision + Text) ---
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-DEIN-KEY-HIER
AI_VISION_MODEL=gpt-4o-mini
AI_TEXT_MODEL=gpt-4o-mini
AI_TIMEOUT=120
AI_MAX_RETRIES=3
NGINX_AI_TIMEOUT=600

# --- Optional: Benachrichtigungen (ntfy.sh ist kostenlos) ---
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=finefits-sophia
# NTFY_TOKEN=

# --- Optional: Hintergrundentfernung auf dem Pi (CPU-lastig) ---
# BG_REMOVAL_MODEL=u2netp
# Leichteres Modell spart RAM/Zeit auf dem Pi

# --- DNS (nur wenn OIDC-Host intern nicht auflösbar ist) ---
# LOCAL_DNS=192.168.1.1
